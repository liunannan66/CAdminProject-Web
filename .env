# 应用的基础URL，默认为 "/"
# 如果使用子目录，必须以 "/" 结尾，例如 "/admin/" 而非 "/admin"
VITE_BASE_URL=/

VITE_APP_TITLE=管理系统

VITE_APP_DESC=管理系统是一款清新雅致的管理后台模板

# 图标名称的前缀
VITE_ICON_PREFIX=icon

# 本地SVG图标组件的前缀，必须包含 VITE_ICON_PREFIX
# 格式为 {VITE_ICON_PREFIX}-{本地图标名称}
VITE_ICON_LOCAL_PREFIX=icon-local

# 权限路由模式：static（静态）｜ dynamic（动态）
VITE_AUTH_ROUTE_MODE=dynamic

# 静态权限路由的首页
VITE_ROUTE_HOME=home

# 默认菜单图标
VITE_MENU_ICON=mdi:menu

# 开发模式下是否启用HTTP代理
VITE_HTTP_PROXY=no

# vue-router 模式：hash | history | memory
VITE_ROUTER_HISTORY_MODE=history

# 后端服务的成功状态码，接收到该状态码时表示请求成功
VITE_SERVICE_SUCCESS_CODE=0000

# 后端服务的登出状态码，接收到该状态码时用户将被登出并重定向到登录页
VITE_SERVICE_LOGOUT_CODES=8888,8889

# 后端服务的弹窗式登出状态码，接收到该状态码时将通过弹窗提示用户登出
VITE_SERVICE_MODAL_LOGOUT_CODES=7777,7778

# 后端服务的令牌过期状态码，接收到该状态码时将刷新令牌并重发请求
VITE_SERVICE_EXPIRED_TOKEN_CODES=9999,9998,3333

# 当路由模式为静态时，定义的超级角色标识
VITE_STATIC_SUPER_ROLE=R_SUPER

# 源码映射（sourcemap）开关
VITE_SOURCE_MAP=N

# 用于区分不同域名下的本地存储（localStorage/sessionStorage）
VITE_STORAGE_PREFIX=SOY_

# 用于控制程序是否自动检测更新
VITE_AUTOMATICALLY_DETECT_UPDATE=Y

# 在终端中显示代理URL日志
VITE_PROXY_LOG=Y

# 用于控制是否启动编辑器跳转功能
# 注：该插件仅在开发模式下可用，构建模式下无效
VITE_DEVTOOLS_LAUNCH_EDITOR=code
